</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
    // 1. Initialize Lenis for buttery smooth scrolling
    const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // standard ease
        direction: 'vertical',
        gestureDirection: 'vertical',
        smooth: true,
        mouseMultiplier: 1,
        smoothTouch: false,
        touchMultiplier: 2,
        infinite: false,
    });

    // Sync GSAP ticker with Lenis (if we use GSAP later, good for parallax)
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(0);

    // 2. Intersection Observer for Reveal animations
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                // Optional: Stop observing once revealed
                // observer.unobserve(entry.target); 
            }
        });
    }, {
        threshold: 0.15, // trigger when 15% visible
        rootMargin: "0px 0px -50px 0px"
    });

    document.querySelectorAll('.reveal-up, .reveal-text').forEach((el) => {
        observer.observe(el); // initial kickoff
        // Ensure elements currently in view pop in
        const rect = el.getBoundingClientRect();
        if(rect.top < window.innerHeight) { el.classList.add('in-view'); }
    });

    // 3. Simple Parallax on images using GSAP and ScrollTrigger
    gsap.utils.toArray('.brutal-image').forEach(image => {
        gsap.to(image, {
            yPercent: 20, // Move the image down slightly as we scroll
            ease: "none",
            scrollTrigger: {
                trigger: image.parentElement,
                start: "top bottom", 
                end: "bottom top",
                scrub: true
            }
        });
    });

    // 4. Update Time
    function updateTime() {
        const now = new Date();
        const timeStr = now.toLocaleTimeString('en-GB', { hour12: false });
        const timeEl = document.getElementById('current-time');
        if (timeEl) timeEl.innerText = timeStr;
    }
    setInterval(updateTime, 1000);
    updateTime();

    // 5. Modal Logic
    const modal = document.getElementById('exp-modal');
    const backdrop = document.getElementById('modal-backdrop');
    const closeBtn = document.getElementById('modal-close');
    
    // Content nodes
    const mTitle = document.getElementById('modal-title');
    const mDate = document.getElementById('modal-date');
    const mDesc = document.getElementById('modal-desc');
    const mGallery = document.getElementById('modal-gallery');

    // Hardcoded dummy image mappings for showcase
    const showcaseImages = {
        'Studio Namma': ['https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=800', 'https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=800'],
        'Kinetix Space': ['https://images.unsplash.com/photo-1550859491-19011afb96f5?q=80&w=800', 'https://images.unsplash.com/photo-1574169208507-84376144848b?q=80&w=800'],
        'Void Interface': ['https://images.unsplash.com/photo-1551244072-5d12893278ab?q=80&w=800'],
        'Prop Films': ['https://images.unsplash.com/photo-1493246507139-91e8fad9978e?q=80&w=800', 'https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=800']
    };

    function openModal(btn) {
        const company = btn.getAttribute('data-company');
        mTitle.innerText = company;
        mDate.innerText = btn.getAttribute('data-date');
        mDesc.innerText = btn.getAttribute('data-desc');
        
        mGallery.innerHTML = ''; // clear old images
        if (showcaseImages[company]) {
            showcaseImages[company].forEach(url => {
                const img = document.createElement('img');
                img.src = url;
                mGallery.appendChild(img);
            });
        }

        modal.classList.add('open');
        lenis.stop(); // Stop scroll while modal is up
    }

    function closeModal() {
        modal.classList.remove('open');
        lenis.start(); // Restore scroll
    }

    document.querySelectorAll('.view-details-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            openModal(btn);
        });
    });

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);


});
</script>
